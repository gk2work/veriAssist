# Copy this to .env and adjust as needed

# Ollama service URL (used by backend)
# In Docker Compose this is automatically set to http://ollama:11434
# For local development without Docker: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Frontend API base URL (build-time variable)
# Leave empty in Docker (nginx proxies /api → backend)
# For local dev without Docker: http://localhost:8000
VITE_API_BASE=http://localhost:8000
