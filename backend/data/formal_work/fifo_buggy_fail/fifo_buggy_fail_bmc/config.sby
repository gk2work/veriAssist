[options]
mode bmc
depth 20
timeout 300

[engines]
smtbmc

[script]
read -formal fifo_buggy_fail.sv
read -formal fifo_formal_checker_monitor.sv
read -formal formal_wrapper.sv
prep -top formal_wrapper

[files]
