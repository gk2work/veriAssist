[options]
mode bmc
depth 10
timeout 300

[engines]
smtbmc

[script]
read -formal fsm_correct_pass.sv
read -formal fsm_formal_checker_monitor.sv
read -formal formal_wrapper.sv
prep -top formal_wrapper

[files]
fsm_correct_pass.sv src/fsm_correct_pass.sv
fsm_formal_checker_monitor.sv src/fsm_formal_checker_monitor.sv
formal_wrapper.sv src/formal_wrapper.sv
